{
  "name": "whisper-gpu-dev",
  "image": "nvcr.io/nvidia/pytorch:25.04-py3",
  "runArgs": [
    "--gpus=all",
    "--ipc=host",
    "--ulimit=memlock=-1",
    "--ulimit=stack=67108864",
    "--shm-size=16g"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "postCreateCommand": "pip install openai-whisper sounddevice numpy"
}